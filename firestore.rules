rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isLoggedIn() {
      return request.auth != null;
    }

    function hasEmail() {
      return isLoggedIn() && request.auth.token.email is string;
    }

    function isOwner(email) {
      return hasEmail() && request.auth.token.email.lower() == email.lower();
    }

    function signedInUserDoc() {
      let email = request.auth.token.email.lower();
      return /databases/$(database)/documents/users/$(email);
    }

    function signedInUserExists() {
      return hasEmail() && exists(signedInUserDoc());
    }

    function hasRole(role) {
      return signedInUserExists()
        && get(signedInUserDoc()).data.role is string
        && get(signedInUserDoc()).data.role.lower() == role.lower();
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isSeller() {
      return hasRole('Seller');
    }

    function isDeliveryPartner() {
      return hasRole('DeliveryPartner');
    }

    match /categories/{categoryId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /users/{email} {
      allow read: if isLoggedIn();
      allow create: if isOwner(email);
      allow update: if isOwner(email) || isAdmin();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isLoggedIn();
      allow create: if isSeller() || isAdmin();
      allow delete: if isAdmin();
      allow update: if (
          isLoggedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQuantity'])
        ) || isSeller() || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    match /cart_items/{itemId} {
      allow read, delete: if hasEmail() && resource.data.email.lower() == request.auth.token.email.lower();
      allow create: if hasEmail() && request.resource.data.email.lower() == request.auth.token.email.lower();
      allow update: if hasEmail() && request.resource.data.email.lower() == request.auth.token.email.lower();
    }

    match /wishlist_items/{itemId} {
      allow read, delete: if hasEmail() && resource.data.email.lower() == request.auth.token.email.lower();
      allow create: if hasEmail() && request.resource.data.email.lower() == request.auth.token.email.lower();
      allow update: if hasEmail() && resource.data.email.lower() == request.auth.token.email.lower();
    }

    match /reviews/{reviewId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    match /banners/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /shortcuts/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /app_config/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /withdrawal_requests/{reqId} {
      allow read: if isDeliveryPartner() || isSeller() || isAdmin();
      allow create: if isDeliveryPartner() || isSeller();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
